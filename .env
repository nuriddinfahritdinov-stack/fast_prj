# ═══════════════════════════════════════════════════════════════
#  DRE Lab — Environment Variables
#  Скопируйте в .env и настройте под свою среду:
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Web Server ────────────────────────────────────────────────
DRE_PORT=8080

# ── PostgreSQL Sandbox ────────────────────────────────────────
POSTGRES_USER=dre
POSTGRES_PASSWORD=dre_password
POSTGRES_DB=drelab
PG_EXTERNAL_PORT=5432

# ── MongoDB Sandbox ───────────────────────────────────────────
MONGO_DB=drelab
MONGO_EXTERNAL_PORT=27017

# ── Sandbox Terminal ──────────────────────────────────────────
# Таймаут сессии терминала (секунды). 600 = 10 минут
SESSION_TIMEOUT=600
